# URL pública do site (usada nos redirects do Mercado Pago)
NEXT_PUBLIC_SITE_URL=http://localhost:3200

# Mercado Pago — https://www.mercadopago.com.br/developers/panel/app
# Token de teste começa com TEST- (sandbox automático)
MERCADOPAGO_ACCESS_TOKEN=

# Sanity — preencha após criar o projeto (npm create sanity@latest)
# Sem estes valores o site usa o catálogo local de demonstração
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Neon Postgres — pedidos (schema em db/001_orders.sql)
# Connection string do projeto no console.neon.tech
DATABASE_URL=

# Painel /admin
ADMIN_PASSWORD=

# Frete: nenhuma env necessária. lib/shipping.ts resolve o estado do
# CEP via BrasilAPI (pública, sem token) e aplica tabela fixa por
# região a partir de Belém-PA — ver REGIONS em lib/shipping.ts
